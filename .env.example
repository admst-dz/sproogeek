# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production

# ─── DATABASE ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=rootpassword
POSTGRES_DB=spruzhuk
DATABASE_USER=postgres
DATABASE_PASSWORD=rootpassword
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=spruzhuk
# Optional legacy override. Prefer DATABASE_* parts when the password contains URL-reserved chars.
DATABASE_URL=

# ─── BACKEND ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=43200
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
ALLOWED_HOSTS=
SENTRY_DSN=

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── KAFKA (optional) ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=

# ─── ADMIN BACKDOOR (DEV ONLY) ───────────────────────────────────────────────
ADMIN_BACKDOOR_ENABLED=false
ADMIN_BACKDOOR_LOGIN=
ADMIN_BACKDOOR_PASSWORD=
ADMIN_BACKDOOR_KEY=
ADMIN_BACKDOOR_EMAIL=admin@spruzhyk.internal

# ─── RENDERER ────────────────────────────────────────────────────────────────
RENDERER_URL=http://renderer:3000
RENDER_MAX_CONCURRENCY=2
RENDER_PAGE_TIMEOUT_MS=15000

# ─── TECHCARD SERVICE ────────────────────────────────────────────────────────
TECHCARD_URL=http://techcard:8000
MANUFACTURER_NAME=ООО «Спружык»
MANUFACTURER_ID=SPRUZHYK-001

# ─── S3 / MINIO ──────────────────────────────────────────────────────────────
# Dev: leave defaults to use local MinIO
MINIO_ROOT_USER=spruzhyk
MINIO_ROOT_PASSWORD=spruzhyk-dev-secret
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=spruzhyk
S3_SECRET_KEY=spruzhyk-dev-secret
S3_BUCKET=techcards

# ─── UPLOAD LIMITS ───────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=12000000
MAX_LOGO_BYTES=2000000
